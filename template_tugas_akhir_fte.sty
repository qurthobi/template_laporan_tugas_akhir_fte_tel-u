\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{template_tugas_akhir_fte}[2026/06/22 v2.0 Template Tugas Akhir FTE]

% =========================================================
% PACKAGES
% =========================================================

% Page layout
\RequirePackage[left=40mm, right=30mm, top=30mm, bottom=30mm]{geometry}
% \RequirePackage{showframe}

% Language and font
\RequirePackage[main=indonesian]{babel}
\RequirePackage{mathptmx}

% Text formatting
\RequirePackage{setspace}
\RequirePackage{indentfirst}
\RequirePackage[none]{hyphenat}

% Figures, tables, captions
\RequirePackage{graphicx}
\RequirePackage{caption}
\RequirePackage{multirow}
\RequirePackage{multicol}
\RequirePackage{arydshln}

% Lists and sections
\RequirePackage{enumitem}
\RequirePackage{titlesec}
\RequirePackage{tocloft}

% Code and boxes
\RequirePackage{tcolorbox}
\RequirePackage{listings}

% References and hyperlinks
\RequirePackage[
  backend=biber,
  bibstyle=ieee,
  citestyle=numeric-comp,
  sorting=none,
  giveninits=true,
  doi=true,
  url=true,
  isbn=true,
  maxbibnames=99,
  maxcitenames=99,
  date=year,
  language=indonesian
]{biblatex}
\RequirePackage{hyperref}

% Glossaries
\usepackage[acronym,nonumberlist]{glossaries}

% Dummy text
\RequirePackage{lipsum}


% =========================================================
% SETTINGS
% =========================================================

% -------------------------
% Bibliography
% -------------------------
\addbibresource{referensi.bib}

\renewcommand*{\multinamedelim}{\addcomma\space}
\renewcommand*{\finalnamedelim}{\addcomma\addspace dan\space}

%Perbaikan untuk istilah  pada daftar pustaka
\DefineBibliographyStrings{indonesian}{%
  url = {Tersedia pada},
}

\AtBeginBibliography{%
  \fontsize{12pt}{12pt}\selectfont
}

% -------------------------
% Captions
% -------------------------
\captionsetup{
  font={stretch=1.15},
  tableposition=top,
  figureposition=bottom,
  labelfont=bf
}

% -------------------------
% Hyphenation
% -------------------------
\hyphenpenalty=10000
\exhyphenpenalty=10000
\emergencystretch=3em

% -------------------------
% Chapter, section, subsection format
% -------------------------
\titleformat{\chapter}
  [display]
  {\large\centering\bfseries}
  {\MakeUppercase{\chaptername}\ \thechapter}
  {0em}
  {\MakeUppercase}

\titlespacing*{\chapter}
  {0pt}
  {-2em}
  {1em}

\titleformat{\section}
  {\normalsize\bfseries}
  {\thesection}
  {1em}
  {}

\titleformat{\subsection}
  {\normalsize\bfseries}
  {\thesubsection}
  {1em}
  {}

% -------------------------
% Paragraphs
% -------------------------
\setlength{\parindent}{2em}
\setlength{\parskip}{0em}

% -------------------------
% Indonesian names
% -------------------------
\addto\captionsindonesian{%
  \renewcommand{\contentsname}{DAFTAR ISI}
  \renewcommand{\listfigurename}{DAFTAR GAMBAR}
  \renewcommand{\listtablename}{DAFTAR TABEL}
  \renewcommand{\bibname}{DAFTAR PUSTAKA}
}

% -------------------------
% ToC, LoF, LoT title format
% -------------------------
\makeatletter

\renewcommand{\cfttoctitlefont}{\hfill\bfseries\large}
\renewcommand{\cftaftertoctitle}{\hfill\hfill}

\renewcommand{\cftloftitlefont}{\hfill\large\bfseries}
\renewcommand{\cftafterloftitle}{\hfill}

\renewcommand{\cftlottitlefont}{\hfill\large\bfseries}
\renewcommand{\cftafterlottitle}{\hfill}

\setlength{\cftbeforetoctitleskip}{0pt}
\setlength{\cftaftertoctitleskip}{2em}

\setlength{\cftbeforeloftitleskip}{0pt}
\setlength{\cftafterloftitleskip}{2em}

\setlength{\cftbeforelottitleskip}{0pt}
\setlength{\cftafterlottitleskip}{2em}

\makeatother

% -------------------------
% ToC numbering prefixes
% -------------------------
\renewcommand{\cftchappresnum}{BAB~}
\renewcommand{\cftchapaftersnum}{\quad}
\setlength{\cftchapnumwidth}{4em}

% -------------------------
% List of Figures prefix
% -------------------------
\renewcommand{\cftfigpresnum}{Gambar~}
\renewcommand{\cftfigaftersnum}{\quad}
\setlength{\cftfignumwidth}{6em}

% -------------------------
% List of Tables prefix
% -------------------------
\renewcommand{\cfttabpresnum}{Tabel~}
\renewcommand{\cfttabaftersnum}{\quad}
\setlength{\cfttabnumwidth}{6em}

\endinput
